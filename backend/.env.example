# DATABASE
DB_HOST="host"
DB_NAME="name"
DB_USER="user"
DB_PASS="pass"

# AUTH
AUTH_JWT_SECRET="secret"
AUTH_LOGIN_EXPIRES_IN="1d"

# API
API_PORT="3000"
