SERVER_PORT=8080
SPRING_APPLICATION_NAME=JBOF-Backend

SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=100GB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=100GB
SERVER_TOMCAT_MAX_HTTP_FORM_POST_SIZE=100GB
SERVER_TOMCAT_MAX_SWALLOW_SIZE=-1

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:35432/jbof
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password

SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_OPEN_IN_VIEW=false
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_JDBC_TIME_ZONE=UTC
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=classpath:db/migration

STORAGE_S3_ENDPOINT=http://localhost:9002
STORAGE_S3_ACCESS_KEY=minio
STORAGE_S3_SECRET_KEY=minio123
STORAGE_S3_REGION=us-east-1
STORAGE_S3_PATH_STYLE=true

MULTIPART_MAX_FILE_SIZE=100
MULTIPART_MAX_REQUEST_SIZE=100

SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_RABBITMQ_VIRTUAL_HOST=/
SPRING_RABBITMQ_LISTENER_SIMPLE_DEFAULT_REQUEUE_REJECTED=false
SPRING_RABBITMQ_TEMPLATE_MANDATORY=true

PAGINATION_MAX_PAGE_SIZE=200

APP_RABBITMQ_DEFAULT_EXCHANGE=
APP_RABBITMQ_DEFAULT_ROUTING_KEY=
APP_RABBITMQ_RECEIVE_TIMEOUT=3000
APP_RABBITMQ_MEDIA_PROCESSING_QUEUE=media.processing
PAGINATION_DEFAULT_SIZE=200

CORS_FRONTEND_URL=https://localhost:4200

SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8081/realms/jbof
AUTH_CLIENT_ID=jbof-backend
AUTH_PRINCIPAL_CLAIM=preferred_username
